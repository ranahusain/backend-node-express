      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rollNumber\": \"21-CS-105\",\n  \"name\": \"Ali Hassan\",\n  \"email\": \"ali.hassan@university.edu\",\n  \"department\": \"Computer Science\",\n  \"cgpa\": 3.78,\n  \"enrollmentYear\": 2021\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/students",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "students"]
        },
        "description": "Create a new student record"
      }
